# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/driver_tracker"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Encryption key for DB-stored provider secrets (32-byte raw or base64)
SETTINGS_ENCRYPTION_KEY="replace-with-32-byte-key"

# Optional: auto-seed default users on first startup when DB has no users
AUTO_SEED_ON_EMPTY_DB="true"

# Optional: migration retry behavior in Docker startup
MIGRATION_MAX_RETRIES="10"
MIGRATION_RETRY_DELAY_SECONDS="5"

# Optional fallback provider env vars (used only if superuser DB settings are empty)
# EMAIL_TENANT_ID=""
# EMAIL_CLIENT_ID=""
# EMAIL_CLIENT_SECRET=""
# EMAIL_FROM=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
