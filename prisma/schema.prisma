// Prisma schema for Driver Tracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERUSER
  DRIVER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         Role      @default(DRIVER)
  isActive     Boolean   @default(true)
  password     String
  adminPhone   String?   // Phone number for SMS alerts (admins)
  adminEmail   String?   // Email for alert notifications (admins)
  updatedNotificationSettings NotificationSettings[] @relation("NotificationSettingsUpdatedBy")
  checkIns     CheckIn[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model NotificationSettings {
  id                     String   @id @default("default")
  emailTenantId          String?
  emailClientId          String?
  emailClientSecretEnc   String?
  emailFrom              String?
  twilioAccountSid       String?
  twilioAuthTokenEnc     String?
  twilioFromNumber       String?
  updatedBy              User?    @relation("NotificationSettingsUpdatedBy", fields: [updatedById], references: [id])
  updatedById            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Location {
  id        String    @id @default(cuid())
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  isActive  Boolean   @default(true)
  checkIns  CheckIn[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CheckIn {
  id           String    @id @default(cuid())
  driver       User      @relation(fields: [driverId], references: [id])
  driverId     String
  location     Location  @relation(fields: [locationId], references: [id])
  locationId   String
  checkInTime  DateTime  @default(now())
  checkInRequestKey String? @unique
  checkOutTime DateTime?
  checkOutRequestKey String? @unique
  latitude     Float?
  longitude    Float?
  alertLevel   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
