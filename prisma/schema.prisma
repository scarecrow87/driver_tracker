// Prisma schema for Driver Tracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERUSER
  DRIVER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         Role      @default(DRIVER)
  isActive     Boolean   @default(true)
  password     String
  adminPhone   String?   // Phone number for SMS alerts (admins)
  adminEmail   String?   // Email for alert notifications (admins)
  // --- SMS/Driver fields ---
  driverPhone                String?
  driverSmsSendOnCheckIn     Boolean @default(false)
  driverSmsSendOnCheckOut    Boolean @default(false)
  driverSmsOptOut            Boolean @default(false)
  adminSmsOptOutTier1        Boolean @default(false)
  adminSmsOptOutTier2        Boolean @default(false)
  adminSmsOptOutTier3        Boolean @default(false)
  // ---
  updatedNotificationSettings NotificationSettings[] @relation("NotificationSettingsUpdatedBy")
  checkIns     CheckIn[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model NotificationSettings {
  id                     String   @id @default("default")
  emailTenantId          String?
  emailClientId          String?
  emailClientSecretEnc   String?
  emailFrom              String?
  twilioAccountSid       String?
  twilioAuthTokenEnc     String?
  twilioFromNumber       String?
  inboundSmsEnabled      Boolean  @default(false) // Superuser can enable/disable inbound SMS
  updatedBy              User?    @relation("NotificationSettingsUpdatedBy", fields: [updatedById], references: [id])
  updatedById            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model SmsAuditLog {
  id               String   @id @default(cuid())
  recipientPhone   String
  messageBody      String   @db.Text
  triggerType      String   // "admin-alert", "driver-checkin-confirm", "driver-checkout-confirm", "manual-trigger", "inbound-checkin", "inbound-checkout"
  checkInId        String?
  initiatedByUserId String?
  twilioSid        String?
  twilioStatus     String   @default("queued")
  error            String?
  direction        String   @default("outbound") // "outbound" or "inbound"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Location {
  id        String    @id @default(cuid())
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  isActive  Boolean   @default(true)
  checkIns  CheckIn[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CheckIn {
  id           String    @id @default(cuid())
  driver       User      @relation(fields: [driverId], references: [id])
  driverId     String
  location     Location  @relation(fields: [locationId], references: [id])
  locationId   String
  checkInTime  DateTime  @default(now())
  checkInRequestKey String? @unique
  checkOutTime DateTime?
  checkOutRequestKey String? @unique
  latitude     Float?
  longitude    Float?
  alertLevel   Int       @default(0)
  isExtendedStay     Boolean   @default(false)
  extendedStayReason String?
  extendedStayAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
